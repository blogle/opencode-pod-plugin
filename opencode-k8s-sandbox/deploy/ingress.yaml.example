# Example Ingress for opencode-k8s-sandbox-router
# This is a template - customize for your ingress controller
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: opencode-k8s-sandbox-router
  namespace: opencode-sandbox
  labels:
    app.kubernetes.io/name: opencode-k8s-sandbox-router
    app.kubernetes.io/managed-by: opencode-k8s-sandbox
  annotations:
    # Example for Traefik:
    # traefik.ingress.kubernetes.io/router.entrypoints: websecure
    # traefik.ingress.kubernetes.io/router.tls: "true"
    # traefik.ingress.kubernetes.io/router.tls.certresolver: letsencrypt
    #
    # Example for nginx-ingress:
    # nginx.ingress.kubernetes.io/ssl-redirect: "true"
    # nginx.ingress.kubernetes.io/proxy-body-size: "10m"
spec:
  ingressClassName: nginx  # Change to your ingress class
  tls:
    - hosts:
        - "*.opencode.example.com"  # Change to your base domain
      secretName: opencode-wildcard-tls
  rules:
    - host: "*.opencode.example.com"  # Change to your base domain
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: opencode-k8s-sandbox-router
                port:
                  number: 8080
