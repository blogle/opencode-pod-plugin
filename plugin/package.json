{
  "name": "@opencode/k8s-sandbox-plugin",
  "version": "0.1.0",
  "description": "Plugin for opencode K8s sandbox integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["opencode", "kubernetes", "sandbox"],
  "license": "MIT",
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "@opencode-ai/plugin": "latest",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  }
}
